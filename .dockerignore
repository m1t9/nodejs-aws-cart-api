# Version control
.git
.gitignore

# Node modules — reinstalled inside the image
node_modules
**/node_modules

# Build output — rebuilt in the builder stage
dist
build
out
coverage

# Package manager logs and caches
.npm
.yarn

# Editor / IDE / OS files
.vscode
.idea
.DS_Store

# Secrets — inject at runtime, never bake into the image
.env
.env.*
env.example

# Tests and dev tooling
test
tests
**/*.spec.ts
**/*.spec.js
**/*.test.ts
**/*.test.js
.eslintrc*
.eslintignore
.prettierrc*
.prettierignore

# Infrastructure-as-code
cdk
cdk.out

# Docs and helper scripts
README.md
README*
*.md
get-token.sh

# Logs and runtime output
logs
*.log

# Temp files, archives, backups
tmp
temp
.tmp
